{
  "title": "PostgreSQL — Performance & Health",
  "description": "Connections, deadlocks, database size, and row operations via OpenTelemetry",
  "time_range": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "type": "metric", "uid": "pg-kpi-conn",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "dataset": { "type": "esql", "query": "FROM metrics-postgresqlreceiver.otel-default | STATS `Active Connections` = MAX(`postgresql.backends`)" },
      "metrics": [{ "type": "primary", "operation": "value", "column": "Active Connections" }]
    },
    {
      "type": "metric", "uid": "pg-kpi-dead",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "dataset": { "type": "esql", "query": "FROM metrics-postgresqlreceiver.otel-default | STATS `Total Deadlocks` = MAX(`postgresql.deadlocks`)" },
      "metrics": [{ "type": "primary", "operation": "value", "column": "Total Deadlocks" }]
    },
    {
      "type": "metric", "uid": "pg-kpi-size",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "dataset": { "type": "esql", "query": "FROM metrics-postgresqlreceiver.otel-default | STATS `Max DB Size` = MAX(`postgresql.db_size`)" },
      "metrics": [{ "type": "primary", "operation": "value", "column": "Max DB Size" }]
    },
    {
      "type": "metric", "uid": "pg-kpi-maxconn",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "dataset": { "type": "esql", "query": "FROM metrics-postgresqlreceiver.otel-default | STATS `Connection Limit` = MAX(`postgresql.connection.max`)" },
      "metrics": [{ "type": "primary", "operation": "value", "column": "Connection Limit" }]
    },
    {
      "type": "xy", "uid": "pg-conn-trend",
      "title": "Active Connections Over Time",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 11 },
      "layers": [{ "type": "area_stacked",
        "dataset": { "type": "esql", "query": "FROM metrics-postgresqlreceiver.otel-default | STATS backends = AVG(`postgresql.backends`) BY bucket = BUCKET(@timestamp, 75, ?_tstart, ?_tend), `postgresql.database.name` | WHERE `postgresql.database.name` IS NOT NULL" },
        "x": { "operation": "value", "column": "bucket" },
        "y": [{ "operation": "value", "column": "backends" }],
        "breakdown_by": { "operation": "value", "column": "postgresql.database.name" }
      }]
    },
    {
      "type": "xy", "uid": "pg-size-bars",
      "title": "Database Size by Database",
      "grid": { "x": 24, "y": 5, "w": 24, "h": 11 },
      "layers": [{ "type": "bar_horizontal",
        "dataset": { "type": "esql", "query": "FROM metrics-postgresqlreceiver.otel-default | STATS db_size = MAX(`postgresql.db_size`) BY `postgresql.database.name` | WHERE `postgresql.database.name` IS NOT NULL | SORT db_size DESC | LIMIT 10" },
        "x": { "operation": "value", "column": "postgresql.database.name" },
        "y": [{ "operation": "value", "column": "db_size" }]
      }]
    },
    {
      "type": "xy", "uid": "pg-deadlocks",
      "title": "Deadlocks Over Time by Database",
      "grid": { "x": 0, "y": 16, "w": 24, "h": 11 },
      "layers": [{ "type": "bar_stacked",
        "dataset": { "type": "esql", "query": "FROM metrics-postgresqlreceiver.otel-default | STATS deadlocks = MAX(`postgresql.deadlocks`) BY bucket = BUCKET(@timestamp, 75, ?_tstart, ?_tend), `postgresql.database.name` | WHERE `postgresql.database.name` IS NOT NULL" },
        "x": { "operation": "value", "column": "bucket" },
        "y": [{ "operation": "value", "column": "deadlocks" }],
        "breakdown_by": { "operation": "value", "column": "postgresql.database.name" }
      }]
    },
    {
      "type": "xy", "uid": "pg-rows",
      "title": "Rows Inserted / Updated / Deleted",
      "grid": { "x": 24, "y": 16, "w": 24, "h": 11 },
      "layers": [{ "type": "line",
        "dataset": { "type": "esql", "query": "FROM metrics-postgresqlreceiver.otel-default | STATS inserted = MAX(`postgresql.tup_inserted`), updated = MAX(`postgresql.tup_updated`), deleted = MAX(`postgresql.tup_deleted`) BY bucket = BUCKET(@timestamp, 75, ?_tstart, ?_tend)" },
        "x": { "operation": "value", "column": "bucket" },
        "y": [{ "operation": "value", "column": "inserted" }, { "operation": "value", "column": "updated" }, { "operation": "value", "column": "deleted" }]
      }]
    }
  ]
}
