#!/bin/bash
set -euo pipefail
cd /root/workshop 2>/dev/null || true

if [ ! -f build/db-monitoring/dashboard-id.txt ]; then
  fail-message "MySQL Database Monitoring dashboard not found. Run the lab setup or Path A script. Expected: build/db-monitoring/dashboard-id.txt"
fi

DASHBOARD_ID="$(cat build/db-monitoring/dashboard-id.txt | tr -d '[:space:]')"
if [ -z "$DASHBOARD_ID" ]; then
  fail-message "Dashboard ID file is empty. Re-run lab setup or Path A."
fi

echo "Lab 3 check passed. Dashboard ID: ${DASHBOARD_ID}"
